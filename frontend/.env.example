# Optional: override alerts worker URL (default: https://turbolong-alerts.workers.dev)
# VITE_ALERTS_WORKER_URL=http://127.0.0.1:8787

# Stellar Broker partner key: DO NOT set this in production builds — anything
# prefixed VITE_ ships in the public JS bundle. In prod the swap WebSocket goes
# through the alerts worker relay (/broker/ws), which injects the key from the
# STELLAR_BROKER_PARTNER_KEY wrangler secret. Only set this locally to bypass
# the relay and hit api.stellar.broker directly during development.
# VITE_STELLAR_BROKER_PARTNER_KEY=dev-only-partner-key
