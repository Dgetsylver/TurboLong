# Turbolong harvest router keeper — environment template.
# Copy to /etc/turbolong/harvest-keeper.env, fill in, chmod 600.
# NEVER commit the filled-in file.

# RPC_URL=https://mainnet.sorobanrpc.com   # override if you run your own RPC

# The deployed strategy IDs (post-D1 deploy). JSON array, one entry per vault:
#   underlyingClassic = Broker classic asset id (CODE-ISSUER, "XLM" for native,
#                       null if the underlying has no classic issuer → Soroswap-only),
#   underlyingSoroban = the SAC contract id of the underlying.
VAULTS_JSON=[{"symbol":"USDC","strategyId":"C...","underlyingClassic":"USDC-GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN","underlyingSoroban":"CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75"}]

# The strategy's keeper account secret (S...). This account must:
#   - be the keeper registered on each strategy (get_keeper()),
#   - be the strategy's swap_account (set_swap_account) for the Broker path,
#   - hold trustlines for classic BLND and each classic underlying it trades,
#   - hold enough XLM for transaction fees.
# Prefer injecting via a secrets manager over storing here if available.
KEEPER_SECRET=S...

# Stellar Broker partner key for the signed trading session (Broker path).
# Without it the Broker websocket session cannot open → Soroswap-only fallback.
STELLAR_BROKER_PARTNER_KEY=

# Slippage tolerance, fraction (0.02 = 2%). Applied to BOTH paths:
# Broker session slippageTolerance and Soroswap amount_out_min.
SLIPPAGE=0.02

# Alerts Worker ingestion (A/B telemetry → D1 swap_routes).
SWAP_ROUTES_URL=https://alerts.example.workers.dev
KEEPER_INGEST_KEY=...

# Skip swapping when the claim is below this (stroops; 10000000 = 1 BLND).
HARVEST_MIN_BLND=10000000

# Harvest pass interval in seconds (emissions accrue slowly; hourly is plenty).
INTERVAL_S=3600

# Max seconds to wait for a Broker trade session before falling back.
BROKER_TRADE_TIMEOUT_S=180

# Audit trail (JSONL). Directory must exist and be writable by the service user:
#   mkdir -p /var/lib/turbolong && chown keeper:keeper /var/lib/turbolong
EVIDENCE_FILE=/var/lib/turbolong/harvest-keeper-log.jsonl
